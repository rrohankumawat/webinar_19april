@using StudentManagementSystem.Dto
@model List<StudentDto>

<div>
    <a href="/Dashboard/AddStudent" class="btn btn-success">Add Student</a>
</div>

<h2>Student Dashboard</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>FatherName</th>
            <th>MotherName</th>
            <th>City</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count() == 0 || Model == null)
        {
            <tr>
                <td colspan="5" class="text-center">No students found.</td>
            </tr>
        }
        
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.FatherName</td>
                <td>@student.MotherName</td>
                <td>@student.City</td>
                <td>
                    <a asp-action="DeleteStudent" asp-route-studentId="@student.Id" class="btn btn-danger">Delete</a>
                    <a asp-action="UpdateStudent" asp-route-studentId="@student.Id" class="btn btn-primary">Update</a>
                </td>
            </tr>
        }
    </tbody>

</table>