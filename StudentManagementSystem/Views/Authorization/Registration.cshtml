@using StudentManagementSystem.Dto
@model UserDto

<div class="container">
    <h2>Registration</h2>
    <form asp-action="RegisterUser">
        <div class="form-group">
            <label>Username</label>
            <input type="text" placeholder="Enter your username ..." name="Username" asp-for="Username"/>
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" placeholder="Enter your password ..." name="Password" asp-for="Password"/>
        </div>
        <div>
            <label>Confirm Password</label>
            <input type="password" placeholder="Confirm your password ..." name="CnfPassword" asp-for="CnfPassword"/>
        </div>
        <div>
            <input class="btn btn-primary" type="submit" />
        </div>
    </form>
</div>


Old user? Go to <a href="/Authorization/Login">Login</a>....