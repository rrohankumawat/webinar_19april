@using StudentManagementSystem.Dto
@model UserDto

<div class="container">
    <h2>Login</h2>
    <form asp-action="LoginUser">
        <div class="form-group">
            <label>Username</label>
            <input type="text" placeholder="Enter your username ..." name="Username" asp-for="Username"/>
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" placeholder="Enter your password ..." name="Password" asp-for="Password"/>
        </div>
        <div>
            <input class="btn btn-primary" type="submit" />
        </div>
    </form>
</div>

New user? Go to <a href="/Authorization/Registration">Registration</a>....